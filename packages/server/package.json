{
  "name": "@agenda/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .aws-sam",
    "sam:validate": "sam validate --lint",
    "sam:build": "npm run build -w @agenda/shared && sam build --build-in-source",
    "sam:local": "npm run sam:build && sam local start-api --port 3000",
    "sam:deploy": "npm run sam:build && sam deploy --guided",
    "deploy": "npm run sam:build && sam deploy"
  },
  "dependencies": {
    "@agenda/shared": "*",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "esbuild": "^0.25.0"
  }
}

{
  "name": "agenda-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @agenda/web",
    "build": "npm run build -w @agenda/shared && npm run build -w @agenda/web && npm run build -w @agenda/server",
    "build:shared": "npm run build -w @agenda/shared",
    "build:web": "npm run build -w @agenda/web",
    "build:server": "npm run build -w @agenda/server",
    "lint": "eslint .",
    "preview": "npm run preview -w @agenda/web",
    "sync": "node server/sync-server.mjs",
    "deploy": "npm run deploy -w @agenda/web"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
